# Navigation
alias ..="cd .."
alias ...="cd ../.."
alias ....="cd ../../.."
alias -- -="cd -"

# Shortcuts
alias dl="cd ~/Downloads"
alias dt="cd ~/Desktop"
alias w="cd ~/workspace"
alias g="git"

# Modern replacements
command -v eza > /dev/null && {
	alias ls="eza"
	alias l="eza -l"
	alias la="eza -la"
	alias lt="eza --tree --level=2"
}
command -v bat > /dev/null && alias cat="bat --paging=never"

# Python
alias python=python3
alias pip=pip3

# Enable aliases to be sudo'ed
alias sudo='sudo '

# IP addresses
alias ip="dig +short myip.opendns.com @resolver1.opendns.com"
alias localip="ipconfig getifaddr en0"

# Flush DNS cache
alias flush="dscacheutil -flushcache && killall -HUP mDNSResponder"

# Trim new lines and copy to clipboard
alias c="tr -d '\n' | pbcopy"

# Recursively delete `.DS_Store` files
alias cleanup="find . -type f -name '*.DS_Store' -ls -delete"

# URL-encode a string
alias urlencode='python3 -c "import sys, urllib.parse as ul; print(ul.quote_plus(sys.argv[1]))"'

# Reload the shell
alias reload="exec $SHELL -l"

# Print each PATH entry on a separate line
alias path='echo -e ${PATH//:/\\n}'

# Cheatsheet for everything in this setup
tools() {
	local B=$'\e[1m' R=$'\e[0m'
	cat <<EOF

${B}MODERN CLI REPLACEMENTS${R}
  rg PATTERN           search inside files (grep, but fast + respects .gitignore)
  fd NAME              find files by name (find)
  bat FILE             view a file with syntax highlighting (cat points to it)
  ls / l / la / lt     eza: modern ls — lt shows a tree, 2 levels deep
  z DIR                jump to a frequent directory by fuzzy name (e.g. \`z work\`)
  zi                   same, but pick interactively
  lazygit              full-featured git TUI

${B}FZF (FUZZY FINDER)${R}
  Ctrl-R               fuzzy-search shell history
  Ctrl-T               fuzzy-pick a file path into the command line
  Alt-C (Esc, then c)  cd into a fuzzy-picked directory
  cmd **<Tab>          fuzzy path completion (e.g. \`vim **<Tab>\`)

${B}RUNTIMES (mise — replaces nvm/rvm/sdkman)${R}
  mise use -g node@lts   install + set global node (same for java@17, ruby, go...)
  mise use node@20       pin a version for the current project
  mise ls                list installed runtimes

${B}GIT (g = git)${R}
  g s                  short status
  g l                  last 20 commits as a graph
  g ca                 add everything + commit
  g amend              fold staged changes into the last commit
  g go BRANCH          switch to branch, creating it if needed
  g linear NUM NAME    create feature/lig-NUM-NAME branch
  g dm                 delete branches already merged
  (diffs are rendered by delta — n/N jumps between files, q quits)

${B}ALIASES${R}
  .. / ... / ....      up 1/2/3 directories;  - goes to previous dir
  w / dl / dt          ~/workspace, ~/Downloads, ~/Desktop
  ip / localip         public / local IP address
  flush                flush the DNS cache
  cleanup              recursively delete .DS_Store files
  c                    trim newlines + copy to clipboard (pipe into it)
  urlencode STR        URL-encode a string
  path                 print PATH entries one per line
  reload               restart the shell

${B}CONFIG${R}
  ~/.extra                  private/machine-specific config — never committed
  ~/.config/starship.toml   prompt config (https://starship.rs/config/)
  tools                     this help

EOF
}
